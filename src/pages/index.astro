---
/**
 * Page d’accueil MuBrain
 * Locale par défaut : français canadien
 * URL : /
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import { defaultLocale } from '@/i18n/config';

const locale = defaultLocale;

const title = 'MuBrain — connaissance structurée pour humains et agents IA';
const description =
  'MuBrain explore la manière de structurer, publier et maintenir la connaissance pour la rendre utile aux humains, aux organisations et aux agents IA.';
---

<LandingLayout
  title={title}
  description={description}
  lang={locale}
  routeId="home"
>
  <main class="min-h-screen">
    <section class="relative overflow-hidden border-b border-border">
      <div class="container mx-auto px-6 py-24 lg:py-32">
        <div class="max-w-4xl">
          <Badge pill>MuBrain</Badge>

          <h1 class="mt-8 text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
            Structurer la connaissance pour les humains et les agents IA.
          </h1>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-foreground-muted">
            MuBrain est un espace de réflexion, de documentation et d’expérimentation autour de
            l’intelligence artificielle, des agents, du doc-as-code, des bases de connaissance
            et des organisations apprenantes.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <Button size="lg" href="/blog/mubrain-foundation/">
              Lire l’article de fondation
            </Button>

            <Button size="lg" variant="outline" href="/blog/">
              Explorer le blog
            </Button>
          </div>
        </div>
      </div>
    </section>

    <section class="container mx-auto px-6 py-20">
      <div class="grid gap-8 lg:grid-cols-3">
        <article class="rounded-2xl border border-border bg-background-subtle p-8">
          <h2 class="text-2xl font-semibold text-foreground">
            Knowledge first
          </h2>
          <p class="mt-4 text-foreground-muted">
            Le site est construit autour d’une base de connaissance structurée, versionnée
            dans GitHub et pensée pour rester lisible par les humains comme par les machines.
          </p>
        </article>

        <article class="rounded-2xl border border-border bg-background-subtle p-8">
          <h2 class="text-2xl font-semibold text-foreground">
            Français canadien source de vérité
          </h2>
          <p class="mt-4 text-foreground-muted">
            Les contenus de référence sont d’abord produits en français canadien. Les versions
            anglaises sont des traductions validées, pas la source principale.
          </p>
        </article>

        <article class="rounded-2xl border border-border bg-background-subtle p-8">
          <h2 class="text-2xl font-semibold text-foreground">
            Prêt pour les agents
          </h2>
          <p class="mt-4 text-foreground-muted">
            La structure OKF / LLM-WIKI documente les concepts, méthodes, projets et décisions
            pour faciliter la réutilisation par ChatGPT, Copilot, Codex ou d’autres agents.
          </p>
        </article>
      </div>
    </section>

    <section class="border-t border-border">
      <div class="container mx-auto px-6 py-20">
        <div class="max-w-3xl">
          <h2 class="text-3xl font-bold tracking-tight text-foreground">
            Une base pour publier, documenter et transmettre.
          </h2>

          <p class="mt-6 text-lg leading-8 text-foreground-muted">
            MuBrain n’est pas seulement un blog. C’est un laboratoire documentaire où les idées,
            les méthodes et les décisions sont conservées dans une structure exploitable à long terme.
          </p>

          <div class="mt-8">
            <Button size="lg" href="/about/">
              Comprendre le projet MuBrain
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>
</LandingLayout>