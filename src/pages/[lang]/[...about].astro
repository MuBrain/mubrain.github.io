---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { locales, isValidLocale, defaultLocale, type Locale } from '@/i18n/config';
import { routes } from '@/i18n/routes';

export function getStaticPaths() {
  return locales
    .filter((lang) => lang !== defaultLocale)
    .map((lang) => ({
      params: {
        lang,
        about: routes.about[lang],
      },
    }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/');
}

const locale = lang as Locale;

const title = 'About MuBrain';
const description =
  'MuBrain is a space for thinking and documenting structured knowledge, artificial intelligence, agents, and learning organizations.';
---

<PageLayout title={title} description={description} lang={locale} routeId="about">
  <section class="border-b border-border bg-secondary py-20">
    <div class="container">
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">
        About
      </p>

      <h1 class="mt-4 max-w-4xl text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
        MuBrain documents how knowledge can remain useful to humans and AI agents.
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-foreground-muted">
        The project starts from a simple belief: knowledge should not only be published.
        It should be structured, versioned, contextualized, and reusable.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="container grid gap-8 lg:grid-cols-3">
      <article class="rounded-2xl border border-border bg-background-subtle p-8">
        <h2 class="text-2xl font-semibold text-foreground">A blog</h2>
        <p class="mt-4 text-foreground-muted">
          MuBrain publishes articles about artificial intelligence, agents, doc-as-code,
          knowledge management, and digital transformation.
        </p>
      </article>

      <article class="rounded-2xl border border-border bg-background-subtle p-8">
        <h2 class="text-2xl font-semibold text-foreground">An OKF base</h2>
        <p class="mt-4 text-foreground-muted">
          Behind the public site, a structured knowledge base preserves concepts, methods,
          projects, and decisions in a format readable by both humans and machines.
        </p>
      </article>

      <article class="rounded-2xl border border-border bg-background-subtle p-8">
        <h2 class="text-2xl font-semibold text-foreground">A lab</h2>
        <p class="mt-4 text-foreground-muted">
          MuBrain is also a place to experiment with ChatGPT, Copilot, Codex, and other agents
          while preserving human control over meaning and decisions.
        </p>
      </article>
    </div>
  </section>

  <section class="border-t border-border py-16">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight text-foreground">
        French Canadian as the source of truth.
      </h2>

      <p class="mt-6 text-lg leading-8 text-foreground-muted">
        Reference content is created in French Canadian first. English versions may be assisted
        or generated by AI, but they must be human-validated before becoming official translations.
      </p>

      <div class="mt-8">
        <Button href="/en/blog/mubrain-foundation/">
          Read the foundation article
        </Button>
      </div>
    </div>
  </section>
</PageLayout>